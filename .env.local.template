# ══════════════════════════════════════════════════
# LEVEN — Environment Variables
# Copy this to .env.local for local dev,
# then add each to Vercel Dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════════

# Supabase — from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — from resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Your deployed app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# Cron secret — make up any random string, paste it here AND in Vercel env vars
# This prevents anyone from triggering your cron endpoint manually
CRON_SECRET=make-up-a-long-random-string-here-abc123xyz
