# ══════════════════════════════════════════════════════════════
# LEVEN — Environment Variables
#
# For LOCAL DEV: copy this file to .env.local (git-ignored)
# For VERCEL:    add each to Vercel → Settings → Environment Variables
#                then REDEPLOY for changes to take effect
# ══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
#
# NOTE: Supabase renamed keys in recent versions:
#   Old name "anon key"          → now called "publishable key"
#   Old name "service_role key"  → now called "secret key"
#   The values work the same — just copy whichever one you see.
#
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend ───────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── App URL ──────────────────────────────────────────────────
# Your live Vercel URL — no trailing slash.
# Set this AFTER first deploy, then redeploy once more.
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# ── Cron Secret ──────────────────────────────────────────────
# Make up any long random string (letters + numbers).
# Use this same value in your cronjob.org URL:
#   https://your-app.vercel.app/api/cron?secret=YOUR_VALUE_HERE
CRON_SECRET=make-up-a-long-random-string-here-abc123xyz

# ══════════════════════════════════════════════════════════════
# CRONJOB.ORG SETUP
# Since Vercel only allows 1 cron job per day on the free tier,
# use cronjob.org to call your endpoint instead:
#
#   1. Go to cronjob.org → New Cron Job
#   2. URL:    https://YOUR-APP.vercel.app/api/cron?secret=YOUR_CRON_SECRET
#   3. Method: GET
#   4. Schedule: every 1 minute (or every 5 min to save quota)
#   5. Save — that's it. No changes needed in Vercel.
# ══════════════════════════════════════════════════════════════
