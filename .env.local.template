# ══════════════════════════════════════════════════════════════
# LEVEN — Environment Variables
# For local dev: copy to .env.local
# For Vercel: add each in Vercel → Settings → Environment Variables → Redeploy
# ══════════════════════════════════════════════════════════════

# Supabase (Settings → API in your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Gmail SMTP (no domain needed — free)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Create one named "Leven" — copy the 16-character password
GMAIL_USER=your.email@gmail.com
GMAIL_PASS=abcd efgh ijkl mnop

# Your live Vercel URL (set after first deploy, then redeploy)
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# Cron secret — any random string, used in your cronjob.org URL
# URL format: https://your-app.vercel.app/api/cron?secret=YOUR_CRON_SECRET
CRON_SECRET=make-up-a-long-random-string-here
